# Application
ENVIRONMENT=local

# Repository — set to "firestore" to use Firestore backend
REPOSITORY_PROVIDER=memory

# LLM Provider — set to "deepseek" to use real provider
LLM_PROVIDER=mock
LLM_MODEL=

# DeepSeek (required only when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi / Moonshot (required only when LLM_PROVIDER=kimi)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# GCP (required for Firestore milestone)
GCP_PROJECT_ID=
FIRESTORE_DATABASE=(default)

# Auth — single admin user (AUTH_ENABLED=true by default)
AUTH_ENABLED=true
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change-me
# Required when AUTH_ENABLED=true. Set a random secret (min 32 chars). Never use a real secret here.
# R-E: this is fail-closed by design — with AUTH_ENABLED=true the API
# REFUSES TO START unless AUTH_TOKEN_SECRET is set (>= 32 chars). That is
# the correct secure default, not a bug. For local dev without auth, set
# ENVIRONMENT=local AND FORGELOOP_ALLOW_NO_AUTH=true AND AUTH_ENABLED=false.
AUTH_TOKEN_SECRET=replace-with-32-byte-random-string
AUTH_TOKEN_TTL_SECONDS=86400

# CORS — comma-separated list of allowed origins (no wildcard default)
# Add your frontend URL when deploying to cloud.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Aider runner (C1) — pure adapter; execution gated and not implemented.
# Defaults to the local Ollama (OLLAMA_BASE_URL / OLLAMA_DEFAULT_MODEL).
AIDER_EXECUTION_ENABLED=false
AIDER_LLM_PROVIDER=ollama
AIDER_MODEL=

# Task 77 — RunnerRouter (speed/cost): pick the fastest safe runner
# (deterministic -> lightweight -> aider -> openhands). OpenHands is NOT
# default: only for broad multi-file work, not auto-selected, and
# approval-gated. Pure decision; execution stays gated by *_ENABLED.
RUNNER_ROUTING_ENABLED=true
DEFAULT_CODING_RUNNER=lightweight
OPENHANDS_AUTO_SELECT_ENABLED=false
OPENHANDS_REQUIRE_APPROVAL=true
OPENHANDS_MIN_COMPLEXITY=medium
LIGHTWEIGHT_RUNNER_ENABLED=true
RUNNER_MAX_PARALLEL_LOCAL=1

# Task 78 — layered ContextPack + token-budget reduction (cost control).
# Costly model calls get a budgeted, layered pack instead of raw history;
# over-budget context is structurally reduced (truncate then drop low
# priority layers) and what was excluded is recorded. Compression prefers
# local Ollama, falls back to DeepSeek — never Kimi.
CONTEXTPACK_ENABLED=true
CONTEXTPACK_DEFAULT_TOKEN_BUDGET=12000
CONTEXTPACK_MAX_TOKEN_BUDGET=24000
CONTEXTPACK_COMPRESSION_PROVIDER=ollama
CONTEXTPACK_FALLBACK_PROVIDER=deepseek
CONTEXTPACK_CACHE_ENABLED=true

# Task 79 — local-first cache / ephemeral state (Valkey/Redis).
# Accelerator ONLY, never the source of truth (durable records stay in
# the repository provider). Default is in-memory: no dependency,
# deterministic, used by tests. Set CACHE_PROVIDER=valkey (or redis) +
# CACHE_REDIS_URL to use the Valkey service in docker-compose.local.yml
# (pip install '.[cache]'). Non-critical cache may fall back to memory
# if Redis is down (CACHE_FAIL_OPEN=true); the expensive-provider budget
# guard must NOT trust a degraded cache (RATE_LIMIT_CACHE_FAIL_OPEN=false).
CACHE_PROVIDER=memory
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL_SECONDS=3600
CACHE_CONNECT_TIMEOUT_MS=1000
CACHE_ENABLED=true
CACHE_FAIL_OPEN=true
RATE_LIMIT_CACHE_FAIL_OPEN=false

# Task 80 (Phase A) — durable workflow + event foundation. Local-first;
# defaults are in-memory (no dependency, deterministic, used by tests).
# NATS (EventBus) and Temporal (WorkflowEngine) are designed-for but
# Phase B: selecting them fails fast (no import, nothing to install).
# K3s is an optional spike, documented only — never a default runtime.
EVENT_BUS_PROVIDER=memory
NATS_URL=nats://localhost:4222
WORKFLOW_ENGINE_PROVIDER=memory
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
WORKER_ENABLED=false
WORKER_CONCURRENCY=1

# Task 81 — controlled project-memory vector retrieval. Narrow + OFF by
# default. Indexes summarized knowledge only (project memory, artifact
# summaries, architecture decisions, human feedback, incident/CI
# lessons) — NEVER raw repo/code/logs/secrets/binaries. Default provider
# is a dependency-free deterministic in-memory store; chroma/qdrant/
# pgvector are future local adapters (selecting them fails fast, no
# import). ContextPack uses it only when enabled AND opted in per
# request; bounded by top_k + per-chunk tokens; never source of truth.
VECTOR_RETRIEVAL_ENABLED=false
VECTOR_PROVIDER=memory
VECTOR_TOP_K=5
VECTOR_MAX_CHUNK_TOKENS=800
VECTOR_INDEX_ARTIFACT_SUMMARIES=true
VECTOR_INDEX_RAW_ARTIFACTS=false

# Task 82 — free/local-first observability. In-process Prometheus-text
# /metrics (auth required) + structured JSON event logs. No client lib,
# no OpenTelemetry import (OTEL is a config flag only — heavy dep,
# deferred), no paid monitoring/alerting. All instrumentation is a
# no-op unless OBSERVABILITY_ENABLED and METRICS_ENABLED. Optional local
# Prometheus: docker compose --profile observability up (see
# prometheus.yml). Metrics are aggregate only — never secrets/PII.
OBSERVABILITY_ENABLED=true
METRICS_ENABLED=true
METRICS_PATH=/metrics
OTEL_ENABLED=false
STRUCTURED_LOGS_ENABLED=true

# Task 83 — advisory-only auto-remediation. OFF by default. Even when
# enabled it is ADVISORY: CI/incident/PR-review findings become a
# RemediationProposal draft; a human Approval is REQUIRED before a
# DevTask is created. ForgeLoop never auto-merges, auto-deploys, or
# creates branches/PRs from remediation. ADVISORY_ONLY=true forbids the
# branch/PR flags (enforced at startup).
AUTO_REMEDIATION_ENABLED=false
AUTO_REMEDIATION_ADVISORY_ONLY=true
AUTO_REMEDIATION_CREATE_TASKS_REQUIRE_APPROVAL=true
AUTO_REMEDIATION_ALLOW_BRANCH_CREATION=false
AUTO_REMEDIATION_ALLOW_PR_CREATION=false

# Model routing (#46) — Kimi is an EXPENSIVE provider, gated, NOT a
# default. Local-first; DeepSeek is the normal hosted fallback; long
# context recommends reduction before any expensive provider; high risk
# requires approval but routes to DeepSeek. Defaults are the safe posture.
MODEL_ROUTING_ENABLED=true
# Task 87: every real LLM call resolves its provider through the
# ModelRouter (resolve_routed_provider). Keep true. Set false only as an
# emergency escape hatch to restore the legacy "request override or
# LLM_PROVIDER" behavior. When LLM_PROVIDER=mock (no real keys), routing
# honors mock so local/test runs need no hosted-provider keys.
MODEL_ROUTING_ENFORCED=true
NORMAL_REASONING_PROVIDER=deepseek
LOCAL_CHEAP_PROVIDER=ollama
EXPENSIVE_PROVIDER=kimi
MODEL_ROUTING_PREFER_LOCAL=true
MODEL_ROUTING_CONTEXT_REDUCTION_FIRST=true
KIMI_REQUIRE_APPROVAL=true
KIMI_AUTO_FALLBACK_ENABLED=false

# Task 76 — provider budget guard (cost control). Every routing decision /
# LLM call is audited via CostRecord (status: planned|completed|failed|
# blocked, selected_provider, routing_reason, fallback_chain,
# was_expensive_provider, required_approval, blocked_reason). The expensive
# provider (Kimi) is fail-closed: blocked without approval, over daily USD
# budget, or over per-task call cap.
PROVIDER_BUDGETS_ENABLED=true
DAILY_KIMI_BUDGET_USD=0.50
DAILY_DEEPSEEK_BUDGET_USD=1.00
MAX_KIMI_CALLS_PER_TASK=3
BUDGET_FAIL_CLOSED_FOR_EXPENSIVE=true

# Kody / Kodus PR review (C3) — real CLI-key HTTP adapter; dormant until
# enabled + a team CLI key (kodus_...). KODY_BASE_URL = your Kodus API host.
KODY_REVIEW_ENABLED=false
KODY_BASE_URL=
KODY_API_KEY=
KODY_REQUEST_TIMEOUT_SECONDS=60
KODY_MAX_RESPONSE_BYTES=2000000
KODY_ASYNC=true

# Langfuse observability (C2) — no-op unless enabled AND all three set.
# Secret key is resolved via the secret provider at runtime; never commit
# a real value here (.env / .env.* are gitignored).
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
