# Application
ENVIRONMENT=local

# Repository — set to "firestore" to use Firestore backend
REPOSITORY_PROVIDER=memory

# LLM Provider — set to "deepseek" to use real provider
LLM_PROVIDER=mock
LLM_MODEL=

# DeepSeek (required only when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Kimi / Moonshot (required only when LLM_PROVIDER=kimi)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# GCP (required for Firestore milestone)
GCP_PROJECT_ID=
FIRESTORE_DATABASE=(default)

# Auth — single admin user (AUTH_ENABLED=true by default)
AUTH_ENABLED=true
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change-me
AUTH_TOKEN_SECRET=replace-with-32-byte-random-string
AUTH_TOKEN_TTL_SECONDS=86400
